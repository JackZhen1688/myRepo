import React from "react";

export default function OfferFormPage() {
  return (
    <div className="min-h-screen bg-gray-100 p-6 flex items-start justify-center">
      <div className="w-full max-w-4xl rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
        {/* Header */}
        <div className="mb-6">
          <h1 className="text-xl font-semibold text-gray-900">
            Basic Information
          </h1>
          <p className="mt-1 text-sm text-gray-500">
            Core details about the offer
          </p>
        </div>

        {/* FieldSet */}
        <FieldSet>
          <FieldGroup>
            {/* Offer Name */}
            <Field>
              <Label required>Offer Name</Label>

              <Input
                placeholder="e.g., Amazon 3x Points"
                type="text"
              />
            </Field>

            {/* Offer Type */}
            <Field>
              <Label required>Offer Type</Label>

              <Select>
                <option>Points Multiplier</option>
                <option>Cash Back</option>
                <option>Discount</option>
                <option>Bonus Reward</option>
              </Select>
            </Field>

            {/* Vendor */}
            <Field>
              <Label>Vendor (Optional)</Label>

              <Input
                placeholder="e.g., Amazon, Target, Starbucks"
                type="text"
              />
            </Field>
          </FieldGroup>
        </FieldSet>
      </div>
    </div>
  );
}

